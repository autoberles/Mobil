<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ── Alap Page stílus ───────────────────────────────────── -->
    <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource DarkGray}"/>
    </Style>

    <!-- ── NavigationPage ─────────────────────────────────────── -->
    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource MediumGray}"/>
        <Setter Property="BarTextColor" Value="{StaticResource TextPrimary}"/>
    </Style>

    <!-- ── Elsődleges gomb (sárga) ────────────────────────────── -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryYellow}"/>
        <Setter Property="TextColor" Value="{StaticResource DarkGray}"/>
        <Setter Property="FontFamily" Value="RajdhaniBold"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="HeightRequest" Value="52"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="FontAttributes" Value="Bold"/>
    </Style>

    <!-- ── Másodlagos gomb (outline) ──────────────────────────── -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="TextColor" Value="{StaticResource PrimaryYellow}"/>
        <Setter Property="FontFamily" Value="RajdhaniSemiBold"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="HeightRequest" Value="48"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderColor" Value="{StaticResource PrimaryYellow}"/>
        <Setter Property="BorderWidth" Value="1.5"/>
    </Style>

    <!-- ── Szöveg gomb (link stílus) ──────────────────────────── -->
    <Style x:Key="TextButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="TextColor" Value="{StaticResource PrimaryYellow}"/>
        <Setter Property="FontFamily" Value="RajdhaniRegular"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="HeightRequest" Value="36"/>
    </Style>

    <!-- ── Input mező ─────────────────────────────────────────── -->
    <Style x:Key="InputEntry" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{StaticResource MediumGray}"/>
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
        <Setter Property="PlaceholderColor" Value="{StaticResource TextHint}"/>
        <Setter Property="FontFamily" Value="RajdhaniRegular"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="HeightRequest" Value="52"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <!-- ── Kártya (autó kártya, stb.) ────────────────────────── -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource CardGray}"/>
        <Setter Property="StrokeShape" Value="RoundRectangle 12"/>
        <Setter Property="Stroke" Value="{StaticResource BorderGray}"/>
        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <!-- ── Szekció cím ────────────────────────────────────────── -->
    <Style x:Key="SectionTitle" TargetType="Label">
        <Setter Property="FontFamily" Value="RajdhaniBold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
        <Setter Property="CharacterSpacing" Value="1.5"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
        <Setter Property="Margin" Value="0,16,0,8"/>
    </Style>

    <!-- ── Főcím ──────────────────────────────────────────────── -->
    <Style x:Key="PageTitle" TargetType="Label">
        <Setter Property="FontFamily" Value="RajdhaniBold"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
    </Style>

    <!-- ── Alcím ──────────────────────────────────────────────── -->
    <Style x:Key="SubTitle" TargetType="Label">
        <Setter Property="FontFamily" Value="RajdhaniRegular"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
    </Style>

    <!-- ── Elválasztó vonal ───────────────────────────────────── -->
    <Style x:Key="Divider" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="1"/>
        <Setter Property="Color" Value="{StaticResource BorderGray}"/>
        <Setter Property="Margin" Value="0,8"/>
    </Style>

    <!-- ── Picker ─────────────────────────────────────────────── -->
    <Style x:Key="FilterPicker" TargetType="Picker">
        <Setter Property="BackgroundColor" Value="{StaticResource MediumGray}"/>
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
        <Setter Property="TitleColor" Value="{StaticResource TextHint}"/>
        <Setter Property="FontFamily" Value="RajdhaniRegular"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="HeightRequest" Value="46"/>
    </Style>

</ResourceDictionary>