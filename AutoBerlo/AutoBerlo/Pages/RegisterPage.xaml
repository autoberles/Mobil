<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AutoBerlo.Pages.RegisterPage"
             NavigationPage.HasNavigationBar="False">

    <ScrollView BackgroundColor="{StaticResource DarkGray}">
        <VerticalStackLayout Padding="32,48,32,32" Spacing="0">

            <!-- Header -->
            <Grid Margin="0,0,0,32" ColumnDefinitions="Auto,*">
                <Button Text="←"
                        Grid.Column="0"
                        Style="{StaticResource TextButton}"
                        Command="{Binding GoBackCommand}"
                        FontSize="22"
                        Padding="0"
                        WidthRequest="36"/>
                <Label Text="Új fiók"
                       Grid.Column="1"
                       Style="{StaticResource PageTitle}"
                       VerticalOptions="Center"
                       Margin="12,0,0,0"/>
            </Grid>

            <!-- Vezetéknév -->
            <Label Text="VEZETÉKNÉV" Style="{StaticResource SectionTitle}"/>
            <Border StrokeShape="RoundRectangle 10"
                    Stroke="{StaticResource BorderGray}"
                    BackgroundColor="{StaticResource MediumGray}"
                    Padding="16,0" HeightRequest="52" Margin="0,0,0,12">
                <Entry Text="{Binding LastName}"
                       Placeholder="Kovács"
                       PlaceholderColor="{StaticResource TextHint}"
                       TextColor="{StaticResource TextPrimary}"
                       FontFamily="RajdhaniRegular"
                       FontSize="15"
                       BackgroundColor="Transparent"/>
            </Border>

            <!-- Keresztnév -->
            <Label Text="KERESZTNÉV" Style="{StaticResource SectionTitle}"/>
            <Border StrokeShape="RoundRectangle 10"
                    Stroke="{StaticResource BorderGray}"
                    BackgroundColor="{StaticResource MediumGray}"
                    Padding="16,0" HeightRequest="52" Margin="0,0,0,12">
                <Entry Text="{Binding FirstName}"
                       Placeholder="András"
                       PlaceholderColor="{StaticResource TextHint}"
                       TextColor="{StaticResource TextPrimary}"
                       FontFamily="RajdhaniRegular"
                       FontSize="15"
                       BackgroundColor="Transparent"/>
            </Border>

            <!-- Email -->
            <Label Text="EMAIL CÍM" Style="{StaticResource SectionTitle}"/>
            <Border StrokeShape="RoundRectangle 10"
                    Stroke="{StaticResource BorderGray}"
                    BackgroundColor="{StaticResource MediumGray}"
                    Padding="16,0" HeightRequest="52" Margin="0,0,0,12">
                <Entry Text="{Binding Email}"
                       Placeholder="pelda@email.hu"
                       PlaceholderColor="{StaticResource TextHint}"
                       TextColor="{StaticResource TextPrimary}"
                       FontFamily="RajdhaniRegular"
                       FontSize="15"
                       Keyboard="Email"
                       BackgroundColor="Transparent"/>
            </Border>

            <!-- Telefonszám -->
            <Label Text="TELEFONSZÁM" Style="{StaticResource SectionTitle}"/>
            <Border StrokeShape="RoundRectangle 10"
                    Stroke="{StaticResource BorderGray}"
                    BackgroundColor="{StaticResource MediumGray}"
                    Padding="16,0" HeightRequest="52" Margin="0,0,0,12">
                <Entry Text="{Binding PhoneNumber}"
                       Placeholder="+36 20 123 4567"
                       PlaceholderColor="{StaticResource TextHint}"
                       TextColor="{StaticResource TextPrimary}"
                       FontFamily="RajdhaniRegular"
                       FontSize="15"
                       Keyboard="Telephone"
                       BackgroundColor="Transparent"/>
            </Border>
            <Label Text="Formátum: +36 20 123 4567"
                FontFamily="RajdhaniRegular"
                FontSize="12"
                TextColor="{StaticResource TextHint}"
                Margin="0,-8,0,12"/>

            <!-- Születési dátum -->
            <Label Text="SZÜLETÉSI DÁTUM" Style="{StaticResource SectionTitle}"/>
            <Border StrokeShape="RoundRectangle 10"
                    Stroke="{StaticResource BorderGray}"
                    BackgroundColor="{StaticResource MediumGray}"
                    Padding="16,0" HeightRequest="52" Margin="0,0,0,12">
                <DatePicker Date="{Binding BirthDate}"
                            Format="yyyy. MM. dd."
                            TextColor="{StaticResource TextPrimary}"
                            BackgroundColor="Transparent"
                            FontFamily="RajdhaniRegular"
                            FontSize="15"/>
            </Border>

            <!-- Jelszó -->
            <Label Text="JELSZÓ" Style="{StaticResource SectionTitle}"/>
            <Border StrokeShape="RoundRectangle 10"
                    Stroke="{StaticResource BorderGray}"
                    BackgroundColor="{StaticResource MediumGray}"
                    Padding="16,0" HeightRequest="52" Margin="0,0,0,12">
                <Entry Text="{Binding Password}"
                       Placeholder="Min. 6 karakter"
                       PlaceholderColor="{StaticResource TextHint}"
                       TextColor="{StaticResource TextPrimary}"
                       FontFamily="RajdhaniRegular"
                       FontSize="15"
                       IsPassword="True"
                       BackgroundColor="Transparent"/>
            </Border>
            <Label Text="Min. 6 karakter, tartalmazzon kisbetűt, nagybetűt és számot"
                FontFamily="RajdhaniRegular"
                FontSize="12"
                TextColor="{StaticResource TextHint}"
                Margin="0,-8,0,12"/>

            <!-- Jelszó megerősítés -->
            <Label Text="JELSZÓ MEGERŐSÍTÉS" Style="{StaticResource SectionTitle}"/>
            <Border StrokeShape="RoundRectangle 10"
                    Stroke="{StaticResource BorderGray}"
                    BackgroundColor="{StaticResource MediumGray}"
                    Padding="16,0" HeightRequest="52" Margin="0,0,0,24">
                <Entry Text="{Binding ConfirmPassword}"
                       Placeholder="••••••••"
                       PlaceholderColor="{StaticResource TextHint}"
                       TextColor="{StaticResource TextPrimary}"
                       FontFamily="RajdhaniRegular"
                       FontSize="15"
                       IsPassword="True"
                       BackgroundColor="Transparent"/>
            </Border>

            <!-- Hibaüzenet -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource ErrorRed}"
                   FontFamily="RajdhaniRegular"
                   FontSize="14"
                   IsVisible="{Binding ErrorMessage,
                               Converter={StaticResource StringToBool}}"
                   Margin="0,0,0,8"/>

            <!-- Sikeres üzenet -->
            <Label Text="{Binding SuccessMessage}"
                   TextColor="{StaticResource SuccessGreen}"
                   FontFamily="RajdhaniRegular"
                   FontSize="14"
                   IsVisible="{Binding SuccessMessage,
                               Converter={StaticResource StringToBool}}"
                   Margin="0,0,0,8"/>

            <!-- Regisztráció gomb -->
            <Button Text="REGISZTRÁCIÓ"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding RegisterCommand}"/>

            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="{StaticResource PrimaryYellow}"
                               Margin="0,8"/>

            <!-- Felhasználási feltételek -->
            <Grid ColumnDefinitions="Auto,*"
                    Margin="0,0,0,20"
                    ColumnSpacing="12">
                <CheckBox Grid.Column="0"
                    IsChecked="{Binding AcceptTerms}"
                    Color="{StaticResource PrimaryYellow}"/>
                <Label Grid.Column="1"
                    VerticalOptions="Center"
                    FontFamily="RajdhaniRegular"
                    FontSize="14"
                    TextColor="{StaticResource TextSecondary}">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Elfogadom a "/>
                            <Span Text="felhasználási feltételeket"
                                TextColor="{StaticResource PrimaryYellow}"
                                TextDecorations="Underline"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>