<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AutoBerlo.Pages.CarDetailPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             Shell.BackButtonBehavior="{x:Null}">

    <Grid RowDefinitions="*,Auto" BackgroundColor="{StaticResource DarkGray}">

        <ActivityIndicator Grid.Row="0"
                   IsRunning="{Binding IsLoading}"
                   IsVisible="{Binding IsLoading}"
                   Color="{StaticResource PrimaryYellow}"
                   VerticalOptions="Center"
                   HorizontalOptions="Center"
                   ZIndex="99"/>

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <Grid HeightRequest="280">
                    <Image Source="{Binding Car.ImgUrl}"
                        Aspect="AspectFill"
                        HeightRequest="280"/>

                    <BoxView BackgroundColor="#CC000000"
                        VerticalOptions="End"
                        HeightRequest="120"/>

                    <Border HorizontalOptions="Start"
                            VerticalOptions="Start"
                            Margin="16,16,0,0"
                            BackgroundColor="#88000000"
                            StrokeShape="RoundRectangle 24"
                            StrokeThickness="0"
                            WidthRequest="48"
                            HeightRequest="48">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                        </Border.GestureRecognizers>
                        <Image Source="arrow_back.svg"
                               WidthRequest="22"
                               HeightRequest="22"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <VerticalStackLayout VerticalOptions="End" Padding="20,0,20,16">
                        <Label Text="{Binding Car.DisplayName}"
               FontFamily="RajdhaniBold"
               FontSize="28"
               TextColor="White"/>
                        <Label Text="{Binding CategoryName}"
               FontFamily="RajdhaniRegular"
               FontSize="14"
               TextColor="{StaticResource PrimaryYellow}"/>
                    </VerticalStackLayout>
                </Grid>

                <VerticalStackLayout Padding="20,20,20,20" Spacing="0">

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,20">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="{Binding Car.PriceDisplay}"
                                   FontFamily="RajdhaniBold"
                                   FontSize="28"
                                   TextColor="{StaticResource PrimaryYellow}"/>
                            <Label Text="naponta"
                                   FontFamily="RajdhaniRegular"
                                   FontSize="13"
                                   TextColor="{StaticResource TextSecondary}"/>
                        </VerticalStackLayout>
                        <Border Grid.Column="1"
                                VerticalOptions="Center"
                                Padding="14,6"
                                StrokeShape="RoundRectangle 20"
                                BackgroundColor="{Binding Car.Availability,
                                                  Converter={StaticResource AvailabilityColor}}">
                            <Label Text="{Binding Car.AvailabilityText}"
                                   FontFamily="RajdhaniBold"
                                   FontSize="13"
                                   TextColor="White"/>
                        </Border>
                    </Grid>

                    <Label Text="MŰSZAKI ADATOK" Style="{StaticResource SectionTitle}"/>
                    <Border BackgroundColor="{StaticResource CardGray}"
                            StrokeShape="RoundRectangle 12"
                            Stroke="{StaticResource BorderGray}"
                            StrokeThickness="1"
                            Padding="16"
                            Margin="0,0,0,12">
                        <Grid ColumnDefinitions="*,*"
                              RowDefinitions="Auto,Auto,Auto,Auto"
                              RowSpacing="12">

                            <VerticalStackLayout Grid.Row="0" Grid.Column="0">
                                <Label Text="ÜZEMANYAG" FontFamily="RajdhaniBold" FontSize="10"
                                       TextColor="{StaticResource TextSecondary}" CharacterSpacing="1"/>
                                <Label Text="{Binding FuelTypeName}"
                                    FontFamily="RajdhaniSemiBold" FontSize="15"
                                    TextColor="{StaticResource TextPrimary}"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="0" Grid.Column="1">
                                <Label Text="VÁLTÓ" FontFamily="RajdhaniBold" FontSize="10"
                                       TextColor="{StaticResource TextSecondary}" CharacterSpacing="1"/>
                                <Label Text="{Binding TransmissionName}"
                                    FontFamily="RajdhaniSemiBold" FontSize="15"
                                    TextColor="{StaticResource TextPrimary}"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="1" Grid.Column="0">
                                <Label Text="TELJESÍTMÉNY" FontFamily="RajdhaniBold" FontSize="10"
                                       TextColor="{StaticResource TextSecondary}" CharacterSpacing="1"/>
                                <Label FontFamily="RajdhaniSemiBold" FontSize="15"
                                       TextColor="{StaticResource TextPrimary}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding Car.PerformanceHp}"/>
                                            <Span Text=" LE / "/>
                                            <Span Text="{Binding Car.PerformanceKw}"/>
                                            <Span Text=" kW"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="1" Grid.Column="1">
                                <Label Text="HAJTÁS" FontFamily="RajdhaniBold" FontSize="10"
                                       TextColor="{StaticResource TextSecondary}" CharacterSpacing="1"/>
                                <Label Text="{Binding WheelDriveName}"
                                    FontFamily="RajdhaniSemiBold" FontSize="15"
                                    TextColor="{StaticResource TextPrimary}"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="2" Grid.Column="0">
                                <Label Text="FÉRŐHELYEK" FontFamily="RajdhaniBold" FontSize="10"
                                       TextColor="{StaticResource TextSecondary}" CharacterSpacing="1"/>
                                <Label Text="{Binding Car.NumberOfSeats, StringFormat='{0} fő'}"
                                       FontFamily="RajdhaniSemiBold" FontSize="15"
                                       TextColor="{StaticResource TextPrimary}"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="2" Grid.Column="1">
                                <Label Text="AJTÓK" FontFamily="RajdhaniBold" FontSize="10"
                                       TextColor="{StaticResource TextSecondary}" CharacterSpacing="1"/>
                                <Label Text="{Binding Car.NumberOfDoors, StringFormat='{0} ajtó'}"
                                       FontFamily="RajdhaniSemiBold" FontSize="15"
                                       TextColor="{StaticResource TextPrimary}"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="3" Grid.Column="0">
                                <Label Text="FUTOTT KM" FontFamily="RajdhaniBold" FontSize="10"
                                       TextColor="{StaticResource TextSecondary}" CharacterSpacing="1"/>
                                <Label Text="{Binding Car.Mileage, StringFormat='{0:N0} km'}"
                                       FontFamily="RajdhaniSemiBold" FontSize="15"
                                       TextColor="{StaticResource TextPrimary}"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="3" Grid.Column="1">
                                <Label Text="SZÍN" FontFamily="RajdhaniBold" FontSize="10"
                                       TextColor="{StaticResource TextSecondary}" CharacterSpacing="1"/>
                                <Label Text="{Binding Car.Color}"
                                       FontFamily="RajdhaniSemiBold" FontSize="15"
                                       TextColor="{StaticResource TextPrimary}"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <Label Text="EXTRA FELSZERELTSÉG" Style="{StaticResource SectionTitle}"/>
                    <Border BackgroundColor="{StaticResource CardGray}"
                            StrokeShape="RoundRectangle 12"
                            Stroke="{StaticResource BorderGray}"
                            StrokeThickness="1"
                            Padding="16"
                            Margin="0,0,0,12">
                        <Grid ColumnDefinitions="*,*"
                              RowDefinitions="Auto,Auto,Auto"
                              RowSpacing="10">

                            <Label Grid.Row="0" Grid.Column="0"
                                   FontFamily="RajdhaniRegular" FontSize="14"
                                   TextColor="{Binding Car.AdditionalEquipment.Navigation,
                                               Converter={StaticResource FeatureColor}}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding Car.AdditionalEquipment.Navigation,
                                                     Converter={StaticResource Checkmark}}"/>
                                        <Span Text="  Navigáció"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <Label Grid.Row="0" Grid.Column="1"
                                   FontFamily="RajdhaniRegular" FontSize="14"
                                   TextColor="{Binding Car.AdditionalEquipment.ParkingSensors,
                                               Converter={StaticResource FeatureColor}}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding Car.AdditionalEquipment.ParkingSensors,
                                                     Converter={StaticResource Checkmark}}"/>
                                        <Span Text="  Parkolóradar"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <Label Grid.Row="1" Grid.Column="0"
                                   FontFamily="RajdhaniRegular" FontSize="14"
                                   TextColor="{Binding Car.AdditionalEquipment.HeatedSeats,
                                               Converter={StaticResource FeatureColor}}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding Car.AdditionalEquipment.HeatedSeats,
                                                     Converter={StaticResource Checkmark}}"/>
                                        <Span Text="  Fűthető ülés"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <Label Grid.Row="1" Grid.Column="1"
                                   FontFamily="RajdhaniRegular" FontSize="14"
                                   TextColor="{Binding Car.AdditionalEquipment.LeatherSeats,
                                               Converter={StaticResource FeatureColor}}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding Car.AdditionalEquipment.LeatherSeats,
                                                     Converter={StaticResource Checkmark}}"/>
                                        <Span Text="  Bőrülés"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <Label Grid.Row="2" Grid.Column="0"
                                   FontFamily="RajdhaniRegular" FontSize="14"
                                   TextColor="{Binding Car.AdditionalEquipment.Tempomat,
                                               Converter={StaticResource FeatureColor}}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding Car.AdditionalEquipment.Tempomat,
                                                     Converter={StaticResource Checkmark}}"/>
                                        <Span Text="  Tempomat"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <VerticalStackLayout Grid.Row="2" Grid.Column="1">
                                <Label Text="KLÍMA"
                                    FontFamily="RajdhaniBold"
                                    FontSize="10"
                                    TextColor="{StaticResource TextSecondary}"
                                    CharacterSpacing="1"/>
                                <Label FontFamily="RajdhaniSemiBold"
                                    FontSize="14"
                                    TextColor="{StaticResource TextPrimary}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding AirConditioningName}"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <Label Text="ÁTVÉTEL HELYE" Style="{StaticResource SectionTitle}"/>
                    <Border BackgroundColor="{StaticResource CardGray}"
                            StrokeShape="RoundRectangle 12"
                            Stroke="{StaticResource BorderGray}"
                            StrokeThickness="1"
                            Padding="16"
                            Margin="0,0,0,12">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding BranchCity}"
                                FontFamily="RajdhaniBold" FontSize="16"
                                TextColor="{StaticResource TextPrimary}"/>
                            <Label Text="{Binding BranchAddress}"
                                FontFamily="RajdhaniRegular" FontSize="14"
                                TextColor="{StaticResource TextSecondary}"/>
                            <Label Text="{Binding BranchPhone}"
                                FontFamily="RajdhaniRegular" FontSize="14"
                                TextColor="{StaticResource PrimaryYellow}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="BÉRLÉS IDŐSZAKA" Style="{StaticResource SectionTitle}"/>
                    <Border BackgroundColor="{StaticResource CardGray}"
                            StrokeShape="RoundRectangle 12"
                            Stroke="{StaticResource BorderGray}"
                            StrokeThickness="1"
                            Padding="16"
                            Margin="0,0,0,12">
                        <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="KEZDETE" FontFamily="RajdhaniBold" FontSize="10"
                                       TextColor="{StaticResource TextSecondary}" CharacterSpacing="1"/>
                                <DatePicker Date="{Binding StartDate}"
                                            Format="yyyy.MM.dd"
                                            TextColor="{StaticResource TextPrimary}"
                                            FontFamily="RajdhaniSemiBold"
                                            FontSize="15"
                                            BackgroundColor="Transparent"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="→"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontSize="18"
                                   VerticalOptions="End"
                                   Margin="0,0,0,4"/>
                            <VerticalStackLayout Grid.Column="2">
                                <Label Text="VÉGE" FontFamily="RajdhaniBold" FontSize="10"
                                       TextColor="{StaticResource TextSecondary}" CharacterSpacing="1"/>
                                <DatePicker Date="{Binding EndDate}"
                                            Format="yyyy.MM.dd"
                                            TextColor="{StaticResource TextPrimary}"
                                            FontFamily="RajdhaniSemiBold"
                                            FontSize="15"
                                            BackgroundColor="Transparent"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <Border BackgroundColor="{StaticResource MediumGray}"
                            StrokeShape="RoundRectangle 12"
                            Stroke="{StaticResource PrimaryYellow}"
                            StrokeThickness="1"
                            Padding="16"
                            Margin="0,4,0,8">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="{Binding TotalDays, StringFormat='{0} nap bérlés'}"
                                       FontFamily="RajdhaniRegular" FontSize="14"
                                       TextColor="{StaticResource TextSecondary}"/>
                                <Label Text="Végösszeg"
                                       FontFamily="RajdhaniRegular" FontSize="13"
                                       TextColor="{StaticResource TextHint}"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="1"
                                   Text="{Binding TotalPrice, StringFormat='{0:N0} Ft'}"
                                   FontFamily="RajdhaniBold" FontSize="26"
                                   TextColor="{StaticResource PrimaryYellow}"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="1"
                BackgroundColor="{StaticResource MediumGray}"
                StrokeThickness="0"
                Padding="20,12,20,28">
            <Button Text="BÉRLÉS MEGKEZDÉSE →"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding ProceedToPaymentCommand}"
                    IsEnabled="{Binding Car.Availability}"/>
        </Border>

    </Grid>
</ContentPage>