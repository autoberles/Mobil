<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AutoBerlo.Pages.ForgotPasswordPage"
             NavigationPage.HasNavigationBar="False">

    <ScrollView BackgroundColor="{StaticResource DarkGray}">
        <VerticalStackLayout Padding="32,48,32,32" Spacing="0">

            <!-- Header -->
            <Grid Margin="0,0,0,32" ColumnDefinitions="Auto,*">
                <Button Text="←"
                        Grid.Column="0"
                        Style="{StaticResource TextButton}"
                        Command="{Binding GoBackCommand}"
                        FontSize="22" Padding="0" WidthRequest="36"/>
                <Label Text="Jelszó visszaállítás"
                       Grid.Column="1"
                       Style="{StaticResource PageTitle}"
                       VerticalOptions="Center"
                       Margin="12,0,0,0"/>
            </Grid>

            <!-- 1. LÉPÉS: Email megadása -->
            <VerticalStackLayout
                IsVisible="{Binding CodeStep,
                            Converter={StaticResource BoolInverter}}"
                Spacing="0">

                <Label Text="Add meg a fiókodhoz tartozó email címet. Elküldünk egy 6 jegyű kódot."
                       Style="{StaticResource SubTitle}"
                       Margin="0,0,0,32"/>

                <Label Text="EMAIL CÍM" Style="{StaticResource SectionTitle}"/>
                <Border StrokeShape="RoundRectangle 10"
                        Stroke="{StaticResource BorderGray}"
                        BackgroundColor="{StaticResource MediumGray}"
                        Padding="16,0" HeightRequest="52" Margin="0,0,0,24">
                    <Entry Text="{Binding Email}"
                           Placeholder="pelda@email.hu"
                           PlaceholderColor="{StaticResource TextHint}"
                           TextColor="{StaticResource TextPrimary}"
                           FontFamily="RajdhaniRegular"
                           FontSize="15"
                           Keyboard="Email"
                           BackgroundColor="Transparent"/>
                </Border>

                <Label Text="{Binding ErrorMessage}"
                       TextColor="{StaticResource ErrorRed}"
                       FontFamily="RajdhaniRegular" FontSize="14"
                       IsVisible="{Binding ErrorMessage,
                                   Converter={StaticResource StringToBool}}"
                       Margin="0,0,0,8"/>

                <Button Text="KÓD KÜLDÉSE"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding SendCodeCommand}"/>

                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"
                                   Color="{StaticResource PrimaryYellow}"
                                   Margin="0,8"/>
            </VerticalStackLayout>

            <!-- 2. LÉPÉS: Kód + új jelszó -->
            <VerticalStackLayout IsVisible="{Binding CodeStep}" Spacing="0">

                <Label Style="{StaticResource SubTitle}" Margin="0,0,0,32">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Elküldtük a kódot a "/>
                            <Span Text="{Binding Email}"
                                  TextColor="{StaticResource PrimaryYellow}"
                                  FontFamily="RajdhaniBold"/>
                            <Span Text=" email címre. A kód 10 percig érvényes."/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>

                <Label Text="6 JEGYŰ KÓD" Style="{StaticResource SectionTitle}"/>
                <Border StrokeShape="RoundRectangle 10"
                        Stroke="{StaticResource BorderGray}"
                        BackgroundColor="{StaticResource MediumGray}"
                        Padding="16,0" HeightRequest="52" Margin="0,0,0,12">
                    <Entry Text="{Binding Code}"
                           Placeholder="123456"
                           PlaceholderColor="{StaticResource TextHint}"
                           TextColor="{StaticResource TextPrimary}"
                           FontFamily="RajdhaniRegular"
                           FontSize="15"
                           Keyboard="Numeric"
                           MaxLength="6"
                           BackgroundColor="Transparent"/>
                </Border>

                <Label Text="ÚJ JELSZÓ" Style="{StaticResource SectionTitle}"/>
                <Border StrokeShape="RoundRectangle 10"
                        Stroke="{StaticResource BorderGray}"
                        BackgroundColor="{StaticResource MediumGray}"
                        Padding="16,0" HeightRequest="52" Margin="0,0,0,12">
                    <Entry Text="{Binding NewPassword}"
                           Placeholder="Min. 6 karakter"
                           PlaceholderColor="{StaticResource TextHint}"
                           TextColor="{StaticResource TextPrimary}"
                           FontFamily="RajdhaniRegular"
                           FontSize="15"
                           IsPassword="True"
                           BackgroundColor="Transparent"/>
                </Border>

                <Label Text="ÚJ JELSZÓ MEGERŐSÍTÉS" Style="{StaticResource SectionTitle}"/>
                <Border StrokeShape="RoundRectangle 10"
                        Stroke="{StaticResource BorderGray}"
                        BackgroundColor="{StaticResource MediumGray}"
                        Padding="16,0" HeightRequest="52" Margin="0,0,0,24">
                    <Entry Text="{Binding ConfirmNewPassword}"
                           Placeholder="••••••••"
                           PlaceholderColor="{StaticResource TextHint}"
                           TextColor="{StaticResource TextPrimary}"
                           FontFamily="RajdhaniRegular"
                           FontSize="15"
                           IsPassword="True"
                           BackgroundColor="Transparent"/>
                </Border>

                <Label Text="{Binding ErrorMessage}"
                       TextColor="{StaticResource ErrorRed}"
                       FontFamily="RajdhaniRegular" FontSize="14"
                       IsVisible="{Binding ErrorMessage,
                                   Converter={StaticResource StringToBool}}"
                       Margin="0,0,0,8"/>

                <Label Text="{Binding SuccessMessage}"
                       TextColor="{StaticResource SuccessGreen}"
                       FontFamily="RajdhaniRegular" FontSize="14"
                       IsVisible="{Binding SuccessMessage,
                                   Converter={StaticResource StringToBool}}"
                       Margin="0,0,0,8"/>

                <Button Text="JELSZÓ MÓDOSÍTÁSA"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ResetPasswordCommand}"/>

                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"
                                   Color="{StaticResource PrimaryYellow}"
                                   Margin="0,8"/>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>