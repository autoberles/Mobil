<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:AutoBerlo.Converters"
             x:Class="AutoBerlo.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:BoolInverterConverter x:Key="BoolInverter"/>
            <conv:StringToBoolConverter x:Key="StringToBool"/>
            <conv:AvailabilityColorConverter x:Key="AvailabilityColor"/>
            <conv:CheckmarkConverter x:Key="Checkmark"/>
            <conv:FeatureColorConverter x:Key="FeatureColor"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>